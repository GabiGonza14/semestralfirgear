# Copiá este archivo como `.env` y completá los valores reales.
# El `.env` está gitignoreado: NUNCA commitees credenciales reales.

# ── Frontend (Vite) ──────────────────────────────────────────────
# Clerk publishable key (es pública, va en el cliente)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
# URL base del backend que consume el frontend
VITE_API_BASE_URL=http://localhost:4000/api

# ── PostHog (monitoreo de errores + analítica, HU-34) ────────────
# La "Project API Key" (phc_...) es PÚBLICA por diseño: se inyecta en el bundle
# del cliente igual que la publishable key de Clerk. Región US → host de ingesta
# https://us.i.posthog.com. Si VITE_POSTHOG_KEY está vacío, el frontend degrada
# graciosamente (no inicializa PostHog) y la app sigue funcionando.
VITE_POSTHOG_KEY=phc_vwHKqDEXxuNRbFsbTeAGBvNKshuZY3KEfjTBvdTaRbXg
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ── TanStack Start (SSR, migración #107) ─────────────────────────
# Copia server-side de la publishable key para el clerkMiddleware SSR de
# @clerk/tanstack-react-start. Mismo valor que VITE_CLERK_PUBLISHABLE_KEY, pero
# SIN prefijo VITE_ para que NO se inyecte en el bundle del cliente (lo lee el
# servidor vía process.env). La publishable key es pública igual; lo importante
# es que la SECRET key de abajo jamás lleve prefijo VITE_.
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# ── Backend / docker-compose ─────────────────────────────────────
# Clerk secret key (backend + verificación de sesión SSR de TanStack Start)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
# Stripe en modo test
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Secret del webhook: lo da `stripe listen --print-secret` (o el Dashboard)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Emails transaccionales (SendGrid) — pago fallido (HU-28) y confirmación de
# compra (HU-30). Si SENDGRID_API_KEY está vacío el backend NO envía: solo lo
# registra en logs (fallback graceful), así dev/test no se rompen.
SENDGRID_API_KEY=SG.your_sendgrid_api_key
# Remitente verificado en SendGrid (Single Sender Verification). Formato
# "Nombre <correo>" o solo el correo. DEBE ser el sender verificado.
EMAIL_FROM=FITGEAR <no-reply@example.com>

# PostHog backend (HU-34) — misma Project API Key que el frontend (posthog-node
# también usa la project key para capturar eventos). Opcional: si falta, el
# backend no crea el cliente y las capturas hacen no-op (nunca crashea).
POSTHOG_API_KEY=phc_vwHKqDEXxuNRbFsbTeAGBvNKshuZY3KEfjTBvdTaRbXg
POSTHOG_HOST=https://us.i.posthog.com

# Base de datos.
# - Para usar la Atlas COMPARTIDA del equipo: pedí la URI real por un canal
#   privado (no está en el repo) y pegala acá.
# - El docker-compose.yml base levanta un Mongo LOCAL vacío; si querés que el
#   backend en Docker use Atlas, creá un docker-compose.override.yml local.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fitgear?retryWrites=true&w=majority
