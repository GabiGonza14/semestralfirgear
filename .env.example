# Copiá este archivo como `.env` y completá los valores reales.
# El `.env` está gitignoreado: NUNCA commitees credenciales reales.

# ── Frontend (Vite) ──────────────────────────────────────────────
# Clerk publishable key (es pública, va en el cliente)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
# URL base del backend que consume el frontend
VITE_API_BASE_URL=http://localhost:4000/api

# ── Backend / docker-compose ─────────────────────────────────────
# Clerk secret key (backend)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
# Stripe en modo test
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Secret del webhook: lo da `stripe listen --print-secret` (o el Dashboard)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Emails transaccionales (SendGrid) — pago fallido (HU-28) y confirmación de
# compra (HU-30). Si SENDGRID_API_KEY está vacío el backend NO envía: solo lo
# registra en logs (fallback graceful), así dev/test no se rompen.
SENDGRID_API_KEY=SG.your_sendgrid_api_key
# Remitente verificado en SendGrid (Single Sender Verification). Formato
# "Nombre <correo>" o solo el correo. DEBE ser el sender verificado.
EMAIL_FROM=FITGEAR <no-reply@example.com>

# Base de datos.
# - Para usar la Atlas COMPARTIDA del equipo: pedí la URI real por un canal
#   privado (no está en el repo) y pegala acá.
# - El docker-compose.yml base levanta un Mongo LOCAL vacío; si querés que el
#   backend en Docker use Atlas, creá un docker-compose.override.yml local.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fitgear?retryWrites=true&w=majority
