# Copiá este archivo como `backend/.env` y completá los valores reales.
# Se usa cuando corrés el backend FUERA de Docker (`bun run dev`).
# Dentro de Docker, estas variables vienen de docker-compose.
# El `.env` está gitignoreado: NUNCA commitees credenciales reales.

PORT=4000

# Base de datos.
# - Atlas COMPARTIDA del equipo: pedí la URI real por un canal privado.
# - O tu Mongo local: mongodb://127.0.0.1:27017/fitgear
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fitgear?retryWrites=true&w=majority

# Clerk secret key (backend)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# Stripe en modo test
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Secret del webhook: lo da `stripe listen --print-secret` (o el Dashboard)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# PostHog (monitoreo de errores + analítica, HU-34). Opcional: si POSTHOG_API_KEY
# está vacío, el cliente no se crea y las capturas hacen no-op (degradación
# graciosa, igual que SendGrid). La Project API Key (phc_...) es pública por
# diseño. Región US → host de ingesta https://us.i.posthog.com.
POSTHOG_API_KEY=phc_vwHKqDEXxuNRbFsbTeAGBvNKshuZY3KEfjTBvdTaRbXg
POSTHOG_HOST=https://us.i.posthog.com
